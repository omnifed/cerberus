{
  "name": "cerberus",
  "version": "0.0.0",
  "description": "The official design system factory for Omnifederal.",
  "license": "ISC",
  "author": "developers@omnifederal.com",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "start:docs": "pnpm --filter docs run dev",
    "lint:es": "eslint . --max-warnings=0",
    "lint:ox": "oxlint --deny-warnings",
    "lint:packages": "pnpm --filter @cerberus-design/* run -w lint:ts",
    "lint:tests": "pnpm --filter tests run lint:ts",
    "lint": "pnpm lint:packages && pnpm lint:tests",
    "test": "pnpm --filter tests run test:ci",
    "ci:version": "changeset version && bun ./configs/src/bump-versions.mjs --stable && pnpm install --no-frozen-lockfile"
  },
  "dependencies": {
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "@types/mdx": "^2.0.14",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "catalog:oxc",
    "oxlint": "^1.73.0"
  },
  "lint-staged": {
    "**/*": "oxfmt --write --no-error-on-unmatched-pattern",
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx}": "oxlint --fix"
  },
  "engines": {
    "bun": ">=1.2.16",
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@11.10.0"
}
