{
  "name": "design-system",
  "version": "0.0.0",
  "description": "The official design system of Digital University.",
  "license": "ISC",
  "author": "developers@omnifederal.com",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "bump:versions": "pnpm --filter @cerberus-design/configs run bump:versions",
    "start:docs": "pnpm --filter docs run dev",
    "lint:es": "eslint . --max-warnings=0",
    "lint:ox": "oxlint --deny-warnings",
    "lint:website": "pnpm --filter website run lint:ts",
    "lint:packages": "pnpm --filter @cerberus-design/* run -w lint:ts",
    "lint:tests": "pnpm --filter tests run lint:ts",
    "lint": "pnpm lint:packages && pnpm lint:tests && pnpm lint:website",
    "test": "pnpm --filter tests run test:ci"
  },
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@types/mdx": "^2.0.13",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.32.0",
    "prettier": "3.8.1"
  },
  "lint-staged": {
    "**/*": "oxfmt --write",
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,astro}": [
      "oxlint --fix"
    ]
  },
  "engines": {
    "bun": ">=1.2.16",
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "express-rate-limit": ">=8.2.2",
      "hono": ">=4.12.7",
      "minimatch": ">=10.2.3"
    },
    "ignoredBuiltDependencies": [
      "@tsparticles/engine",
      "bun",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "onlyBuiltDependencies": [
      "@carbon/icon-helpers",
      "@carbon/icons-react"
    ]
  }
}
