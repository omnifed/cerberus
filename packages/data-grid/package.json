{
  "name": "@cerberus-design/data-grid",
  "version": "1.0.0-rc.1",
  "description": "The Cerberus Design React DataGrid component.",
  "keywords": [
    "data grid",
    "data grid component",
    "panda-css",
    "react",
    "react signals",
    "react signals component"
  ],
  "license": "ISC",
  "author": "developers@omnifederal.com",
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "src/index.ts",
  "module": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "./package.json": "./package.json"
    },
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.cts",
    "typesVersions": {
      "*": {
        ".": [
          "dist/index.d.cts"
        ]
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf ./dist",
    "lint:ts": "tsc --project tsconfig.lint.json --noEmit"
  },
  "dependencies": {
    "@cerberus-design/react": "workspace:*",
    "@cerberus-design/signals": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "globby": "^16.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-system": "workspace:*",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "react": "*",
    "react-dom": "*"
  },
  "browserslist": "> 0.25%, not dead"
}
