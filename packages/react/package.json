{
  "name": "@cerberus-design/react",
  "version": "1.0.0-rc.6",
  "description": "The Cerberus Design React component library.",
  "keywords": [
    "css",
    "design-system",
    "digital university",
    "du design system",
    "omni-federal",
    "panda-css",
    "panda-css react",
    "react",
    "ui",
    "ui library"
  ],
  "license": "ISC",
  "author": "developers@omnifederal.com",
  "repository": {
    "url": "https://github.com/omnifed/cerberus"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "src/index.ts",
  "module": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "./*": {
        "import": {
          "types": "./dist/components/*/index.d.ts",
          "default": "./dist/components/*/index.js"
        },
        "require": {
          "types": "./dist/components/*/index.d.cts",
          "default": "./dist/components/*/index.cjs"
        }
      },
      "./package.json": "./package.json"
    },
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.cts",
    "typesVersions": {
      "*": {
        ".": [
          "dist/index.d.cts"
        ],
        "./*": [
          "dist/components/*/index.d.cts"
        ]
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf ./dist",
    "lint:ts": "tsc --project tsconfig.lint.json --noEmit"
  },
  "dependencies": {
    "@ark-ui/react": "^5.34.1",
    "@carbon/icons-react": "^11.76.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "globby": "^16.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-system": "workspace:*",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "@pandacss/dev": "^1.9.0",
    "react": "*",
    "react-dom": "*"
  },
  "browserslist": "> 0.25%, not dead"
}
