{
  "name": "@cerberus-design/react",
  "version": "1.6.0",
  "description": "The Cerberus Design React component library.",
  "keywords": [
    "css",
    "design-system",
    "digital university",
    "du design system",
    "omni-federal",
    "panda-css",
    "panda-css react",
    "react",
    "ui",
    "ui library"
  ],
  "license": "ISC",
  "author": "developers@omnifederal.com",
  "repository": {
    "url": "https://github.com/omnifed/cerberus"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "src/index.ts",
  "module": "src/index.ts",
  "publishConfig": {
    "main": "dist/index.cjs",
    "module": "dist/index.js",
    "types": "dist/index.d.cts",
    "typesVersions": {
      "*": {
        ".": [
          "dist/index.d.cts"
        ],
        "./*": [
          "dist/components/*/index.d.cts"
        ]
      }
    },
    "exports": {
      ".": {
        "import": {
          "types": "./dist/index.d.ts",
          "default": "./dist/index.js"
        },
        "require": {
          "types": "./dist/index.d.cts",
          "default": "./dist/index.cjs"
        }
      },
      "./*": {
        "import": {
          "types": "./dist/components/*/index.d.ts",
          "default": "./dist/components/*/index.js"
        },
        "require": {
          "types": "./dist/components/*/index.d.cts",
          "default": "./dist/components/*/index.cjs"
        }
      },
      "./package.json": "./package.json"
    },
    "access": "public"
  },
  "scripts": {
    "generate:info": "pnpm panda ship --outfile dist/panda.buildinfo.json",
    "build": "vite build && pnpm generate:info",
    "clean": "rm -rf ./dist",
    "lint:ts": "tsc --project tsconfig.lint.json --noEmit"
  },
  "dependencies": {
    "@ark-ui/react": "catalog:ark",
    "@carbon/icons-react": "catalog:jsx"
  },
  "devDependencies": {
    "@cerberus/panda-preset": "workspace:*",
    "@internationalized/date": "^3.12.2",
    "@pandacss/dev": "^1.11.4",
    "@types/react": "catalog:jsx",
    "@types/react-dom": "catalog:jsx",
    "@typescript/typescript6": "catalog:jsx",
    "@vitejs/plugin-react": "catalog:jsx",
    "globby": "catalog:jsx",
    "react": "catalog:jsx",
    "react-dom": "catalog:jsx",
    "styled-system": "workspace:*",
    "vite": "catalog:jsx",
    "vite-plugin-dts": "catalog:jsx"
  },
  "peerDependencies": {
    "@pandacss/dev": "*",
    "react": "*",
    "react-dom": "*"
  },
  "browserslist": "> 0.25%, not dead"
}